{
  "expo": {
    "name": "Maze 3D Explorer",
    "slug": "dmazerunner",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/icon.png",
    "scheme": "dmazerunner",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dmazerunner.app"
    },
    "android": {
      "backgroundColor": "#0A0E1A",
      "package": "com.dmazerunner.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Maze 3D Explorer",
      "shortName": "Maze",
      "description": "A fast-paced 3D maze runner — collect gems, change themes, beat 10,000!",
      "themeColor": "#00FF88",
      "backgroundColor": "#0A0E1A",
      "display": "fullscreen",
      "orientation": "landscape",
      "startUrl": "/",
      "lang": "en",
      "scope": "/"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}